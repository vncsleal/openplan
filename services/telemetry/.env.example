# Stripe — required for subscription billing
STRIPE_SECRET_KEY=sk_test_...

# GitHub OAuth — required for device flow authentication
GITHUB_CLIENT_ID=Ov23...
GITHUB_CLIENT_SECRET=...

# Turso/libSQL database — required for calibration/checkpoint storage
OPENPLAN_DB_URL=libsql://...
OPENPLAN_DB_TOKEN=...

# Admin key — used for internal API management
OPENPLAN_ADMIN_KEY=...

# Optional: base URL for the mesh API (defaults to https://api.openplan.cc)
# OPENPLAN_MESH_URL=https://api.openplan.cc

# Optional: sentry DSN for error tracking
# SENTRY_DSN=

# Required for Stripe webhook signature verification
# STRIPE_WEBHOOK_SECRET=whsec_...
