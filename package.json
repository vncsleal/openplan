{
  "name": "@openplan/mcp",
  "version": "0.1.0",
  "description": "Waze for AI agents — plan, track, and learn from software projects. 3 tools, one job each.",
  "type": "module",
  "bin": {
    "openplan": "dist/cli.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc && shx chmod +x dist/*.js",
    "dev": "tsx watch src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/"
  },
  "dependencies": {
    "fastmcp": "^4.3.0",
    "better-sqlite3": "^11.10.0",
    "commander": "^15.0.0",
    "@clack/prompts": "^1.5.0",
    "picocolors": "^1.1.0",
    "smol-toml": "^1.3.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.9.0",
    "tsx": "^4.19.0",
    "shx": "^0.4.0",
    "vitest": "^3.1.0",
    "@biomejs/biome": "^1.9.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0"
  }
}
